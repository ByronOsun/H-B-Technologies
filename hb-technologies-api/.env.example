# Server
PORT=4000
NODE_ENV=production

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000

# Security
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=15m

# Supabase (server-only; NEVER expose service role key to frontend)
SUPABASE_URL=https://ncixdccigfuinjfoajkw.supabase.co
SUPABASE_SERVICE_ROLE_KEY=change-me-in-render-env

# Email Configuration (for consultation notifications)
# Use a service like SendGrid, Brevo (Sendinblue), Gmail App Password, or AWS SES
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password-not-regular-password

# Rate Limiting Configuration
# Global rate limit: 120 requests per 60 seconds
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# Consultation-specific rate limit: 5 requests per 15 minutes per IP
CONSULTATION_RATE_LIMIT_MAX=5
CONSULTATION_RATE_LIMIT_WINDOW=900000

# Note: For production deployments, use Redis for rate limit storage
# Store: redis (default: memory-based for development)
