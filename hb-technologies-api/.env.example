# Server
PORT=4000
NODE_ENV=production

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000

# Security
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=15m

# Supabase (server-only; NEVER expose service role key to frontend)
SUPABASE_URL=https://ncixdccigfuinjfoajkw.supabase.co
SUPABASE_SERVICE_ROLE_KEY=change-me-in-render-env

# Email Configuration (for consultation notifications)
# Use a service like SendGrid, Brevo (Sendinblue), Gmail App Password, or AWS SES
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password-not-regular-password
EMAIL_FROM="H&B Technologies <htechnob@gmail.com>"

# If your host blocks IPv6 outbound traffic (common on some PaaS), force IPv4 DNS lookups:
# Set to "true" to force IPv4 for SMTP connections
# EMAIL_FORCE_IPV4=true

# SMTP timeout tuning (milliseconds)
# Increase these if your provider is slow to respond; defaults are 10000 ms
# EMAIL_CONNECTION_TIMEOUT_MS=10000
# EMAIL_GREETING_TIMEOUT_MS=10000
# EMAIL_SOCKET_TIMEOUT_MS=10000

# WhatsApp Configuration (Meta WhatsApp Business Cloud API)
# Use a permanent access token or a long-lived system user token
WHATSAPP_ACCESS_TOKEN=your-meta-whatsapp-access-token
WHATSAPP_PHONE_NUMBER_ID=your-whatsapp-phone-number-id
WHATSAPP_RECIPIENT_NUMBER=254700000000

# Optional: use an approved WhatsApp template with one body placeholder for the alert text
WHATSAPP_TEMPLATE_NAME=
WHATSAPP_TEMPLATE_LANGUAGE=en_US
WHATSAPP_API_VERSION=v22.0

# Rate Limiting Configuration
# Global rate limit: 120 requests per 60 seconds
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# Consultation-specific rate limit: 5 requests per 15 minutes per IP
CONSULTATION_RATE_LIMIT_MAX=5
CONSULTATION_RATE_LIMIT_WINDOW=900000

# Note: For production deployments, use Redis for rate limit storage
# Store: redis (default: memory-based for development)
